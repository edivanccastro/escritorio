<Application x:Class="Planilha.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Planilha"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Escritorio.Shared;component/Theme/Ribbon.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Identidade visual da Planilha (verde) -->
            <SolidColorBrush x:Key="AccentBrush" Color="#217346" />
            <SolidColorBrush x:Key="AccentDarkBrush" Color="#185C37" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
