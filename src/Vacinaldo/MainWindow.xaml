<Window x:Class="Vacinaldo.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Vacinaldo"
       Width="1060" Height="720"
       MinWidth="860" MinHeight="560"
       WindowStartupLocation="CenterScreen"
       Background="White"
       Closing="Window_OnClosing">

    <Window.Resources>
        <!-- Botão de navegação lateral -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="Nav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent"
                                Padding="16,0,12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFEBEE"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C62828"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de ação grande -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#8E0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário -->
        <Style x:Key="SecButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#C62828"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFEBEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de sub-tab da página EDR -->
        <Style x:Key="EdrTabBtn" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="EdrTab"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C62828"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card de scan option -->
        <Style x:Key="ScanCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- BARRA DE TÍTULO -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="&#x2665;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Vacinaldo" Style="{StaticResource TitleBarText}"
                               FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text=" &#x2014; Prote&#xE7;&#xE3;o do Sistema" Style="{StaticResource TitleBarText}"
                               Opacity=".75" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Style="{StaticResource TitleBarText}" Text="Escrit&#xF3;rio" Opacity=".7" FontSize="12"/>
                    <TextBlock Style="{StaticResource TitleBarText}" Text="Edi&#xE7;&#xE3;o Comunit&#xE1;ria" Opacity=".55" FontSize="9"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CORPO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navegação lateral -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButton}"
                                 IsChecked="True" Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x2302;  "/><Run Text="In&#xED;cio"/></TextBlock>
                    </RadioButton>
                    <RadioButton x:Name="NavScan" Style="{StaticResource NavButton}"
                                 Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x26B2;  "/><Run Text="Varredura"/></TextBlock>
                    </RadioButton>
                    <RadioButton x:Name="NavQuarantine" Style="{StaticResource NavButton}"
                                 Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x26CA;  "/><Run Text="Quarentena"/></TextBlock>
                    </RadioButton>
                    <RadioButton x:Name="NavHistory" Style="{StaticResource NavButton}"
                                 Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x2630;  "/><Run Text="Hist&#xF3;rico"/></TextBlock>
                    </RadioButton>
                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}"
                                 Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x2699;  "/><Run Text="Configura&#xE7;&#xF5;es"/></TextBlock>
                    </RadioButton>
                    <RadioButton x:Name="NavEdr" Style="{StaticResource NavButton}"
                                 Checked="Nav_Checked">
                        <TextBlock><Run Text="&#x25C8;  "/><Run Text="EDR"/></TextBlock>
                    </RadioButton>

                    <!-- Versão -->
                    <TextBlock Text="v1.0.0 &#x2014; MIT" FontSize="10" Foreground="#BDBDBD"
                               Margin="20,0,0,0" VerticalAlignment="Bottom"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Páginas -->
            <Grid Grid.Column="1" x:Name="PagesRoot">

                <!-- DASHBOARD -->
                <ScrollViewer x:Name="PageDashboard" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="36,32,36,36">
                        <!-- Status principal -->
                        <Border x:Name="StatusCard" Background="#E8F5E9" CornerRadius="12"
                                Padding="28,24" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="StatusIcon" Text="&#x2714;" FontSize="36" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatusTitle" Text="Protegido"
                                               FontSize="22" FontWeight="Bold" Foreground="#2E7D32"/>
                                    <TextBlock x:Name="StatusDesc"
                                               Text="Seu sistema est&#xE1; protegido. Nenhuma amea&#xE7;a encontrada."
                                               FontSize="13" Foreground="#4CAF50" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="LastScanText" Text="&#xDA;ltima varredura: nunca"
                                               FontSize="12" Foreground="#888" Margin="0,8,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Varredura R&#xE1;pida"
                                        Style="{StaticResource ActionButton}"
                                        VerticalAlignment="Center"
                                        Click="QuickScan_OnClick"/>
                            </Grid>
                        </Border>

                        <!-- Cards de informação -->
                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="10" Padding="20,16" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="&#x2705;" FontSize="28"/>
                                    <TextBlock x:Name="RealTimeStatus" Text="Ativa"
                                               FontSize="18" FontWeight="Bold" Foreground="#388E3C" Margin="0,6,0,0"/>
                                    <TextBlock Text="Prote&#xE7;&#xE3;o em Tempo Real" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="10" Padding="20,16" Margin="6,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="&#x26CA;" FontSize="28"/>
                                    <TextBlock x:Name="QuarantineCount" Text="0"
                                               FontSize="18" FontWeight="Bold" Foreground="#C62828" Margin="0,6,0,0"/>
                                    <TextBlock Text="Em Quarentena" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="10" Padding="20,16" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="&#x2630;" FontSize="28"/>
                                    <TextBlock x:Name="ScanCount" Text="0"
                                               FontSize="18" FontWeight="Bold" Foreground="#1565C0" Margin="0,6,0,0"/>
                                    <TextBlock Text="Varreduras Realizadas" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Ações rápidas -->
                        <TextBlock Text="A&#xE7;&#xF5;es R&#xE1;pidas" FontSize="15" FontWeight="Bold"
                                   Margin="0,0,0,14" Foreground="#333"/>
                        <UniformGrid Columns="3">
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,10,0"
                                    Content="Varredura R&#xE1;pida" Click="QuickScan_OnClick"/>
                            <Button Style="{StaticResource SecButton}" Margin="5,0,5,0"
                                    Content="Varredura Completa" Click="FullScan_OnClick"/>
                            <Button Style="{StaticResource SecButton}" Margin="10,0,0,0"
                                    Content="Varredura Personalizada" Click="CustomScan_OnClick"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <!-- VARREDURA -->
                <Grid x:Name="PageScan" Visibility="Collapsed" Margin="36,32,36,36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Varredura" FontSize="22" FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- Opções de varredura -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource ScanCard}" Margin="0,0,10,0"
                                MouseLeftButtonUp="QuickScanCard_Click">
                            <StackPanel>
                                <TextBlock Text="&#x26A1;" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Varredura R&#xE1;pida" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="&#xC1;reas de alto risco: Desktop, Downloads, Temp"
                                           FontSize="11" Foreground="#888" Margin="0,4,0,12" TextWrapping="Wrap"/>
                                <Button Style="{StaticResource ActionButton}" Content="Iniciar"
                                        Click="QuickScan_OnClick" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource ScanCard}" Margin="5,0,5,0"
                                MouseLeftButtonUp="FullScanCard_Click">
                            <StackPanel>
                                <TextBlock Text="&#x2714;" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Varredura Completa" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Todos os arquivos do usu&#xE1;rio e Arquivos de Programas"
                                           FontSize="11" Foreground="#888" Margin="0,4,0,12" TextWrapping="Wrap"/>
                                <Button Style="{StaticResource SecButton}" Content="Iniciar"
                                        Click="FullScan_OnClick" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource ScanCard}" Margin="10,0,0,0"
                                MouseLeftButtonUp="CustomScanCard_Click">
                            <StackPanel>
                                <TextBlock Text="&#x2699;" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Varredura Personalizada" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Escolha uma pasta espec&#xED;fica para verificar"
                                           FontSize="11" Foreground="#888" Margin="0,4,0,12" TextWrapping="Wrap"/>
                                <Button Style="{StaticResource SecButton}" Content="Escolher Pasta"
                                        Click="CustomScan_OnClick" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Progresso + resultados -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Barra de progresso -->
                        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0"
                                BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ScanStatusText" Text="Aguardando varredura..."
                                               FontSize="12" Foreground="#555"/>
                                    <Button Grid.Column="1" x:Name="StopButton"
                                            Content="&#x23F9; Parar" Style="{StaticResource SecButton}"
                                            Padding="12,4" FontSize="11" Visibility="Collapsed"
                                            Click="StopScan_OnClick"/>
                                </Grid>
                                <ProgressBar Grid.Row="1" x:Name="ScanProgress"
                                             Height="6" IsIndeterminate="True" Visibility="Collapsed"
                                             Foreground="#C62828" Background="#FFCDD2"/>
                                <TextBlock Grid.Row="2" x:Name="ScanFileText" Text=""
                                           FontSize="10" Foreground="#AAA" Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- Lista de ameaças encontradas -->
                        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ThreatCountLabel"
                                                   Text="Amea&#xE7;as encontradas: 0"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                                        <Button Grid.Column="1" x:Name="QuarantineAllBtn"
                                                Content="Quarentenar Todos"
                                                Style="{StaticResource SecButton}"
                                                Padding="10,4" FontSize="11"
                                                Visibility="Collapsed"
                                                Click="QuarantineAll_OnClick"/>
                                    </Grid>
                                </Border>
                                <ListView Grid.Row="1" x:Name="ThreatList"
                                          BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Arquivo" Width="320"
                                                DisplayMemberBinding="{Binding FilePath}"/>
                                            <GridViewColumn Header="Amea&#xE7;a" Width="180"
                                                DisplayMemberBinding="{Binding ThreatName}"/>
                                            <GridViewColumn Header="N&#xED;vel" Width="80"
                                                DisplayMemberBinding="{Binding LevelLabel}"/>
                                            <GridViewColumn Header="Detectado" Width="140"
                                                DisplayMemberBinding="{Binding DetectedAtText}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- QUARENTENA -->
                <Grid x:Name="PageQuarantine" Visibility="Collapsed" Margin="36,32,36,36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Quarentena" FontSize="22" FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Style="{StaticResource SecButton}" Margin="0,0,8,0"
                                Content="Restaurar Selecionado" Click="Restore_OnClick"/>
                        <Button Style="{StaticResource SecButton}" Margin="0,0,8,0"
                                Content="Excluir Selecionado" Click="DeleteQuar_OnClick"/>
                        <Button Style="{StaticResource SecButton}"
                                Content="Excluir Tudo" Click="DeleteAllQuar_OnClick"/>
                    </StackPanel>
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                        <ListView x:Name="QuarantineList" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Arquivo Original" Width="300"
                                        DisplayMemberBinding="{Binding OriginalPath}"/>
                                    <GridViewColumn Header="Amea&#xE7;a" Width="180"
                                        DisplayMemberBinding="{Binding ThreatName}"/>
                                    <GridViewColumn Header="N&#xED;vel" Width="80"
                                        DisplayMemberBinding="{Binding LevelLabel}"/>
                                    <GridViewColumn Header="Quarentenado em" Width="160"
                                        DisplayMemberBinding="{Binding DateText}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>

                <!-- HISTÓRICO -->
                <Grid x:Name="PageHistory" Visibility="Collapsed" Margin="36,32,36,36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Hist&#xF3;rico de Varreduras" FontSize="22" FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <Button Grid.Row="1" Style="{StaticResource SecButton}" Margin="0,0,0,14"
                            Content="Limpar Hist&#xF3;rico" Click="ClearHistory_OnClick"
                            HorizontalAlignment="Left"/>
                    <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                        <ListView x:Name="HistoryList" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Data" Width="160"
                                        DisplayMemberBinding="{Binding StartText}"/>
                                    <GridViewColumn Header="Tipo" Width="160"
                                        DisplayMemberBinding="{Binding ScanType}"/>
                                    <GridViewColumn Header="Arquivos" Width="90"
                                        DisplayMemberBinding="{Binding FilesScanned}"/>
                                    <GridViewColumn Header="Amea&#xE7;as" Width="90"
                                        DisplayMemberBinding="{Binding ThreatsFound}"/>
                                    <GridViewColumn Header="Dura&#xE7;&#xE3;o" Width="100"
                                        DisplayMemberBinding="{Binding Duration}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>

                <!-- CONFIGURAÇÕES -->
                <ScrollViewer x:Name="PageSettings" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="36,32,36,36">
                        <TextBlock Text="Configura&#xE7;&#xF5;es" FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,24"/>

                        <!-- Proteção em tempo real -->
                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Prote&#xE7;&#xE3;o em Tempo Real"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Monitora novos arquivos criados na pasta do usu&#xE1;rio"
                                               FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" x:Name="RealTimToggle"
                                             IsChecked="True"
                                             Style="{StaticResource RibbonToggle}"
                                             VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Varredura ao iniciar -->
                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Varredura R&#xE1;pida ao Iniciar"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Executa varredura r&#xE1;pida automaticamente ao abrir o Vacinaldo"
                                               FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" x:Name="StartupScanToggle"
                                             Style="{StaticResource RibbonToggle}"
                                             VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Sobre -->
                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="10" Padding="20,16" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Sobre o Vacinaldo" FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="#555" LineHeight="20">
                                    <Run Text="Vacinaldo v1.0.0 &#x2014; Scanner heur&#xED;stico de seguran&#xE7;a"/>
                                    <LineBreak/>
                                    <Run Text="Parte do suite Escrit&#xF3;rio &#xB7; Licen&#xE7;a MIT &#xB7; Software Livre"/>
                                    <LineBreak/>
                                    <Run Text="Detecta: EICAR, dupla extens&#xE3;o, execut&#xE1;veis em Temp, nomes suspeitos"/>
                                    <LineBreak/>
                                    <Run FontStyle="Italic" Foreground="#AAA"
                                         Text="Este software n&#xE3;o substitui uma solu&#xE7;&#xE3;o antiv&#xED;rus comercial completa."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- EDR -->
                <Grid x:Name="PageEdr" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho EDR -->
                    <Border Grid.Row="0" Background="#1A1A2E" Padding="32,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="EDR &#x2014; Detec&#xE7;&#xE3;o e Resposta a Incidentes"
                                           FontSize="19" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Monitoramento comportamental em tempo real &#xB7; an&#xE1;lise bayesiana &#xB7; auditoria imut&#xE1;vel"
                                           FontSize="11" Foreground="#90CAF9" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#0D47A1" CornerRadius="8"
                                    Padding="14,8" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Vacinaldo EDR" Foreground="White"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="Motor Comportamental" Foreground="#90CAF9" FontSize="9"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Barra de sub-tabs -->
                    <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                            Background="White" Padding="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="EdrTabProcess" Style="{StaticResource EdrTabBtn}"
                                             IsChecked="True" Checked="EdrTab_Checked"
                                             Content="Processos"/>
                                <RadioButton x:Name="EdrTabNetwork" Style="{StaticResource EdrTabBtn}"
                                             Checked="EdrTab_Checked" Content="Conex&#xF5;es"/>
                                <RadioButton x:Name="EdrTabTimeline" Style="{StaticResource EdrTabBtn}"
                                             Checked="EdrTab_Checked" Content="Timeline"/>
                                <RadioButton x:Name="EdrTabSaif" Style="{StaticResource EdrTabBtn}"
                                             Checked="EdrTab_Checked" Content="Relat&#xF3;rio EDR"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Atualizar"
                                    Style="{StaticResource SecButton}"
                                    Padding="14,4" FontSize="11" VerticalAlignment="Center"
                                    Click="EdrRefresh_Click"/>
                        </Grid>
                    </Border>

                    <!-- Conteúdo das sub-tabs -->
                    <Grid Grid.Row="2">

                        <!-- Processos -->
                        <Grid x:Name="EdrPageProcess" Margin="24,14,24,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="11" Foreground="#666"
                                Text="Processos em execu&#xE7;&#xE3;o &#x2014; ordenados por n&#xED;vel de risco"/>
                            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                <ListView x:Name="EdrProcessList" BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Processo" Width="150"
                                                DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="PID" Width="58"
                                                DisplayMemberBinding="{Binding Pid}"/>
                                            <GridViewColumn Header="Risco" Width="90"
                                                DisplayMemberBinding="{Binding RiskLabel}"/>
                                            <GridViewColumn Header="Mem&#xF3;ria" Width="75"
                                                DisplayMemberBinding="{Binding Memory}"/>
                                            <GridViewColumn Header="Threads" Width="62"
                                                DisplayMemberBinding="{Binding Threads}"/>
                                            <GridViewColumn Header="MITRE" Width="65"
                                                DisplayMemberBinding="{Binding Mitre}"/>
                                            <GridViewColumn Header="Motivo" Width="270"
                                                DisplayMemberBinding="{Binding Reason}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>

                        <!-- Conexões de Rede -->
                        <Grid x:Name="EdrPageNetwork" Visibility="Collapsed" Margin="24,14,24,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="11" Foreground="#666"
                                Text="Conex&#xF5;es TCP ativas &#x2014; conex&#xF5;es suspeitas listadas primeiro"/>
                            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                <ListView x:Name="EdrNetworkList" BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="IP Remoto" Width="150"
                                                DisplayMemberBinding="{Binding RemoteAddr}"/>
                                            <GridViewColumn Header="Porta" Width="65"
                                                DisplayMemberBinding="{Binding RemotePort}"/>
                                            <GridViewColumn Header="IP Local" Width="130"
                                                DisplayMemberBinding="{Binding LocalAddr}"/>
                                            <GridViewColumn Header="Estado" Width="100"
                                                DisplayMemberBinding="{Binding State}"/>
                                            <GridViewColumn Header="Suspeita?" Width="80"
                                                DisplayMemberBinding="{Binding SuspLabel}"/>
                                            <GridViewColumn Header="Motivo" Width="270"
                                                DisplayMemberBinding="{Binding Reason}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>

                        <!-- Timeline -->
                        <Grid x:Name="EdrPageTimeline" Visibility="Collapsed" Margin="24,14,24,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="11" Foreground="#666" VerticalAlignment="Center"
                                    Text="Linha do tempo de eventos de seguran&#xE7;a &#x2014; gerados pelo motor EDR em tempo real"/>
                                <Button Grid.Column="1" Content="Limpar Timeline"
                                        Style="{StaticResource SecButton}" Padding="12,3"
                                        FontSize="11" Click="EdrClearTimeline_Click"/>
                            </Grid>
                            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                <ListView x:Name="EdrTimelineList" BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Hora" Width="80"
                                                DisplayMemberBinding="{Binding Time}"/>
                                            <GridViewColumn Header="Fonte" Width="120"
                                                DisplayMemberBinding="{Binding Source}"/>
                                            <GridViewColumn Header="Risco" Width="90"
                                                DisplayMemberBinding="{Binding RiskLabel}"/>
                                            <GridViewColumn Header="MITRE" Width="65"
                                                DisplayMemberBinding="{Binding Mitre}"/>
                                            <GridViewColumn Header="T&#xE1;tica" Width="120"
                                                DisplayMemberBinding="{Binding Tactic}"/>
                                            <GridViewColumn Header="Descri&#xE7;&#xE3;o" Width="310"
                                                DisplayMemberBinding="{Binding Description}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>

                        <!-- Relatório EDR -->
                        <ScrollViewer x:Name="EdrPageSaif" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="24,16,24,24">

                                <TextBlock Text="Vacinaldo EDR &#x2014; Arquitetura do Motor de Detec&#xE7;&#xE3;o"
                                           FontSize="15" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#888" FontSize="11" Margin="0,0,0,20"
                                    Text="6 princ&#xED;pios de seguran&#xE7;a implementados no motor de varredura e no motor EDR do Vacinaldo"/>

                                <!-- Princípios de segurança - linha 1 -->
                                <UniformGrid Columns="3" Margin="0,0,0,12">
                                    <Border Background="#E8F5E9" CornerRadius="10" Padding="16,14" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Explicabilidade" FontSize="13" FontWeight="Bold"
                                                       Foreground="#2E7D32" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="Cada detec&#xE7;&#xE3;o inclui sinais individuais, evid&#xEA;ncias e t&#xE9;cnica de ataque classificada."/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#E3F2FD" CornerRadius="10" Padding="16,14" Margin="3,0,3,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Risco Mensur&#xE1;vel" FontSize="13" FontWeight="Bold"
                                                       Foreground="#1565C0" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="Score de confian&#xE7;a 0-100 com acumula&#xE7;&#xE3;o bayesiana."/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FFF8E1" CornerRadius="10" Padding="16,14" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Trilha de Auditoria" FontSize="13" FontWeight="Bold"
                                                       Foreground="#E65100" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="Log JSONL append-only imut&#xE1;vel com timestamp, fonte, t&#xE9;cnica de ataque e desfecho."/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Princípios de segurança - linha 2 -->
                                <UniformGrid Columns="3" Margin="0,0,0,24">
                                    <Border Background="#F3E5F5" CornerRadius="10" Padding="16,14" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Robustez Adversarial" FontSize="13" FontWeight="Bold"
                                                       Foreground="#6A1B9A" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="Detec&#xE7;&#xE3;o de masquerading, LOLBAS, execut&#xE1;veis em Temp, dupla extens&#xE3;o e stub droppers."/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FCE4EC" CornerRadius="10" Padding="16,14" Margin="3,0,3,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Controle de Falso Positivo" FontSize="13" FontWeight="Bold"
                                                       Foreground="#880E4F" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="FP risk calculado por n&#xFA;mero de sinais, peso m&#xE9;dio e contexto."/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#E0F2F1" CornerRadius="10" Padding="16,14" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="&#x2714;" FontSize="22"/>
                                            <TextBlock Text="Classifica&#xE7;&#xE3;o de T&#xE9;cnicas" FontSize="13" FontWeight="Bold"
                                                       Foreground="#00695C" Margin="0,6,0,3"/>
                                            <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap"
                                                Text="15 categorias comportamentais: execu&#xE7;&#xE3;o, persist&#xEA;ncia, evas&#xE3;o, C2, escalada de privil&#xE9;gio e mais."/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Log de auditoria recente -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Log de Auditoria Recente"
                                                   FontSize="14" FontWeight="Bold"/>
                                        <TextBlock x:Name="AuditLogSize" Text=""
                                                   FontSize="10" Foreground="#888"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Limpar Log"
                                            Style="{StaticResource SecButton}"
                                            Padding="12,4" FontSize="11"
                                            Click="EdrClearAudit_Click"/>
                                </Grid>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                                    <ListView x:Name="EdrAuditList" BorderThickness="0" MaxHeight="260">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Data/Hora" Width="130"
                                                    DisplayMemberBinding="{Binding Time}"/>
                                                <GridViewColumn Header="Tipo" Width="120"
                                                    DisplayMemberBinding="{Binding EventType}"/>
                                                <GridViewColumn Header="Fonte" Width="90"
                                                    DisplayMemberBinding="{Binding Source}"/>
                                                <GridViewColumn Header="MITRE" Width="65"
                                                    DisplayMemberBinding="{Binding Mitre}"/>
                                                <GridViewColumn Header="Conf." Width="55"
                                                    DisplayMemberBinding="{Binding Confidence}"/>
                                                <GridViewColumn Header="Desfecho" Width="90"
                                                    DisplayMemberBinding="{Binding Outcome}"/>
                                                <GridViewColumn Header="Descri&#xE7;&#xE3;o" Width="210"
                                                    DisplayMemberBinding="{Binding Description}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </Grid>

            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Pronto" VerticalAlignment="Center"
                           FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="1" x:Name="RtpStatusBar"
                           Text="&#x2705; Prote&#xE7;&#xE3;o: Ativa" VerticalAlignment="Center"
                           FontSize="11" Foreground="#388E3C"/>
            </Grid>
        </Border>
    </Grid>
</Window>
