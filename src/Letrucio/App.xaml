<Application x:Class="Letrucio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Letrucio"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Escritorio.Shared;component/Theme/Ribbon.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Identidade visual do Ordi (azul) -->
            <SolidColorBrush x:Key="AccentBrush" Color="#2B579A" />
            <SolidColorBrush x:Key="AccentDarkBrush" Color="#1E3F73" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

