<Window x:Class="Letrucio.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localizar e Substituir"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">
    <StackPanel Margin="16">
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Localizar:" VerticalAlignment="Center" />
            <TextBox x:Name="FindBox" Grid.Column="1" Height="24" VerticalContentAlignment="Center" />
        </Grid>

        <Grid x:Name="ReplaceRow" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Substituir por:" VerticalAlignment="Center" />
            <TextBox x:Name="ReplaceBox" Grid.Column="1" Height="24" VerticalContentAlignment="Center" />
        </Grid>

        <CheckBox x:Name="MatchCaseBox" Content="Diferenciar maiúsculas/minúsculas" Margin="0,0,0,10" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Localizar Próxima" Padding="10,4" Margin="0,0,8,0" Click="FindNext_OnClick" />
            <Button x:Name="ReplaceButton" Content="Substituir" Padding="10,4" Margin="0,0,8,0" Click="Replace_OnClick" />
            <Button x:Name="ReplaceAllButton" Content="Substituir Tudo" Padding="10,4" Margin="0,0,8,0" Click="ReplaceAll_OnClick" />
            <Button Content="Fechar" Padding="10,4" Click="Close_OnClick" />
        </StackPanel>

        <TextBlock x:Name="StatusLabel" Margin="0,10,0,0" Foreground="#555" />
    </StackPanel>
</Window>

