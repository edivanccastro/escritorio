<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cores padrao (cada app sobrescreve AccentBrush/AccentDarkBrush) -->
    <Color x:Key="AccentColor">#2B579A</Color>
    <Color x:Key="AccentDarkColor">#1E3F73</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
    <SolidColorBrush x:Key="RibbonBackgroundBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="RibbonBorderBrush" Color="#E1E1E1" />
    <SolidColorBrush x:Key="RibbonHoverBrush" Color="#E8EEF7" />
    <SolidColorBrush x:Key="RibbonPressedBrush" Color="#D4E0F2" />
    <SolidColorBrush x:Key="RibbonTextBrush" Color="#2B2B2B" />
    <SolidColorBrush x:Key="RibbonGroupLabelBrush" Color="#6E6E6E" />
    <SolidColorBrush x:Key="CanvasBrush" Color="#E6E6E6" />

    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

    <!-- Barra de titulo (faixa colorida superior) -->
    <Style x:Key="TitleBarText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Botao da Barra de Acesso Rapido -->
    <Style x:Key="QuickAccessButton" TargetType="Button">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#33FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#55FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl no estilo faixa de opcoes -->
    <Style x:Key="RibbonTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource RibbonBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}">
                            <TabPanel IsItemsHost="True"
                                      Margin="8,0,0,0"
                                      Panel.ZIndex="1" />
                        </Border>
                        <Border Grid.Row="1"
                                Background="{StaticResource RibbonBackgroundBrush}"
                                BorderBrush="{StaticResource RibbonBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Aba da faixa de opcoes -->
    <Style x:Key="RibbonTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bd"
                            Background="Transparent"
                            Padding="14,7"
                            Margin="1,4,1,0"
                            CornerRadius="3,3,0,0">
                        <ContentPresenter x:Name="cp"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#22FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentDarkBrush}" />
                            <Setter TargetName="bd" Property="Margin" Value="1,4,1,0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Grupo de comandos dentro da faixa -->
    <Style x:Key="RibbonGroup" TargetType="GroupBox">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Margin" Value="2,4,2,4" />
        <Setter Property="Foreground" Value="{StaticResource RibbonGroupLabelBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource RibbonBorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ContentPresenter VerticalAlignment="Stretch" />
                        </Border>
                        <TextBlock Grid.Row="1"
                                   Margin="0,3,1,2"
                                   HorizontalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{StaticResource RibbonGroupLabelBrush}"
                                   Text="{TemplateBinding Header}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botao grande (glifo em cima, texto embaixo). Tag = glifo -->
    <Style x:Key="RibbonButtonLarge" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinWidth" Value="58" />
        <Setter Property="Foreground" Value="{StaticResource RibbonTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="22"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{TemplateBinding Tag}" />
                            <TextBlock Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="11.5"
                                       TextAlignment="Center"
                                       Foreground="{StaticResource RibbonTextBrush}"
                                       Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botao pequeno (glifo + texto na horizontal). Tag = glifo -->
    <Style x:Key="RibbonButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{StaticResource RibbonTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="15"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{TemplateBinding Tag}" />
                            <TextBlock Margin="7,0,2,0"
                                       VerticalAlignment="Center"
                                       FontSize="12.5"
                                       Foreground="{StaticResource RibbonTextBrush}"
                                       Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botao de alternancia (negrito/italico). Tag = glifo -->
    <Style x:Key="RibbonToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Foreground" Value="{StaticResource RibbonTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonPressedBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botao de alternancia com rotulo (glifo + texto na horizontal). Tag = glifo -->
    <Style x:Key="RibbonLabeledToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{StaticResource RibbonTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="15"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{TemplateBinding Tag}" />
                            <TextBlock Margin="7,0,2,0"
                                       VerticalAlignment="Center"
                                       FontSize="12.5"
                                       Foreground="{StaticResource RibbonTextBrush}"
                                       Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonPressedBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botao quadrado de icone (mesmo visual do toggle, mas para Button) -->
    <Style x:Key="RibbonIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Foreground" Value="{StaticResource RibbonTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RibbonBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RibbonPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Barra de status inferior -->
    <Style x:Key="StatusBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
        <Setter Property="Padding" Value="12,4" />
    </Style>

    <Style x:Key="StatusBarText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Separador vertical fino -->
    <Style x:Key="RibbonSeparator" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{StaticResource RibbonBorderBrush}" />
        <Setter Property="Margin" Value="3,4" />
    </Style>

</ResourceDictionary>
