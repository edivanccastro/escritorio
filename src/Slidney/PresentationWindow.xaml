<Window x:Class="Slidney.PresentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apresentação"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        Background="Black"
        KeyDown="Window_OnKeyDown"
        MouseRightButtonUp="Window_OnMouseRightButtonUp">
    <Grid>
        <Viewbox Stretch="Uniform">
            <Border x:Name="SlideSurface" Width="1280" Height="720">
                <Grid Margin="120,90">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TitleText" Grid.Row="0" Foreground="White"
                               FontSize="72" FontWeight="Bold" TextWrapping="Wrap" />
                    <TextBlock x:Name="ContentText" Grid.Row="1" Margin="0,40,0,0" Foreground="#F2F2F2"
                               FontSize="40" TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Viewbox>

        <TextBlock x:Name="PagerText" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,24,18" Foreground="#80FFFFFF" FontSize="16" />
        <TextBlock Text="← → para navegar · Esc para sair" HorizontalAlignment="Left"
                   VerticalAlignment="Bottom" Margin="24,0,0,18" Foreground="#55FFFFFF" FontSize="14" />
    </Grid>
</Window>
