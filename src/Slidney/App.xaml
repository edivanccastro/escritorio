<Application x:Class="Slidney.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Slidney"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Escritorio.Shared;component/Theme/Ribbon.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Identidade visual do Slidney (laranja) -->
            <SolidColorBrush x:Key="AccentBrush" Color="#C43E1C" />
            <SolidColorBrush x:Key="AccentDarkBrush" Color="#A33417" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
