<Window x:Class="EspiaDesk.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EspiaDesk — Chat da Sessão"
        Width="360" Height="520"
        MinWidth="280" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CanvasBrush}"
        Icon="pack://application:,,,/Assets/espiadisk.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="10,6">
            <TextBlock Text="💬  Chat da Sessão" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
        </Border>

        <!-- Mensagens -->
        <ScrollViewer Grid.Row="1" x:Name="Scroll" VerticalScrollBarVisibility="Auto"
                      Padding="8" Background="{DynamicResource CanvasBrush}">
            <StackPanel x:Name="MsgPanel" />
        </ScrollViewer>

        <!-- Input -->
        <Grid Grid.Row="2" Margin="8" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"    />
                <ColumnDefinition Width="8"    />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtInput" Grid.Column="0"
                     Style="{StaticResource ModernTextBox}"
                     KeyDown="Input_KeyDown"
                     AcceptsReturn="False"/>
            <Button Grid.Column="2" Content="Enviar"
                    Style="{StaticResource AccentButton}"
                    Click="Send_Click"/>
        </Grid>
    </Grid>
</Window>
