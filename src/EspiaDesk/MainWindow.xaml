<Window x:Class="EspiaDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EspiaDesk - Acesso Remoto"
        Width="860" Height="600"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasBrush}"
        Icon="pack://application:,,,/Assets/espiadisk.ico"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barra de título -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="3" Background="White" Margin="0,0,8,0">
                        <TextBlock Text="E" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                    <TextBlock Style="{StaticResource TitleBarText}" Text="EspiaDesk" FontSize="13"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Style="{StaticResource TitleBarText}"
                           HorizontalAlignment="Center" Text="Acesso Remoto" />
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource TitleBarText}" Text="Escrit&#xF3;rio" Opacity="0.85" FontSize="12"/>
                    <TextBlock Style="{StaticResource TitleBarText}" Text="Edição Comunitária" Opacity="0.6" FontSize="9"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Faixa de opções -->
        <TabControl Grid.Row="1" Style="{StaticResource RibbonTabControl}" SelectedIndex="0">
            <TabItem Style="{StaticResource RibbonTabItem}" Header="Início">
                <StackPanel Orientation="Horizontal" Height="96">
                    <GroupBox Style="{StaticResource RibbonGroup}" Header="Servidor">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE72E;" Content="Iniciar" Click="StartServer_Click" x:Name="BtnStartServer"/>
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE711;" Content="Parar"   Click="StopServer_Click"  x:Name="BtnStopServer" IsEnabled="False"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Style="{StaticResource RibbonGroup}" Header="Sessões">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE8BB;" Content="Histórico" Click="History_Click"/>
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE7BA;" Content="Encerrar Todas" Click="KickAll_Click"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Style="{StaticResource RibbonGroup}" Header="Ferramentas">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE713;" Content="Configurações" Click="Settings_Click"/>
                            <Button Style="{StaticResource RibbonButtonLarge}" Tag="&#xE7F4;" Content="Sobre"         Click="About_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Conteúdo principal -->
        <Grid Grid.Row="2" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Painel: Seu ID -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="20">
                    <TextBlock Text="Seu código de acesso" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Compartilhe com quem vai acessar este dispositivo"
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,0,0,12"/>

                    <!-- Código de acesso em destaque -->
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="0,14"
                            Cursor="Hand" MouseLeftButtonUp="CopyId_Click" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="TxtMyId" Text="ED-000000"
                                       FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Clique para copiar o código" FontSize="10"
                                       Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Senha -->
                    <TextBlock Text="Senha de acesso" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="PwdBox" Grid.Column="0"
                                     Style="{StaticResource ModernPasswordBox}"
                                     PasswordChanged="PwdBox_Changed"/>
                        <Button Grid.Column="2" Content="Aplicar"
                                Style="{StaticResource AccentButton}"
                                Click="ApplyPwd_Click"/>
                    </Grid>

                    <!-- Status servidor -->
                    <Separator Margin="0,12" Background="{DynamicResource BorderBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ServerDot" Width="8" Height="8" Fill="#E74C3C" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtServerStatus" Text="Servidor parado"
                                   Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtLocalIp" Text="" FontSize="10"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="TxtSessions" Text="0 sessões ativas"
                               FontSize="10" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Painel: Conectar -->
            <Border Grid.Column="2" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <StackPanel Margin="20">
                    <TextBlock Text="Conectar a outro dispositivo" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Digite o código ou endereço IP do host"
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,0,0,12"/>

                    <TextBlock Text="Código ou IP remoto" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtRemoteId"
                             Style="{StaticResource ModernTextBox}"
                             FontSize="16" Padding="8,8"
                             KeyDown="TxtRemoteId_KeyDown"/>

                    <TextBlock Text="Senha (opcional)" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,4"/>
                    <PasswordBox x:Name="PwdRemote"
                                 Style="{StaticResource ModernPasswordBox}"/>

                    <Button x:Name="BtnConnect"
                            Content="▶  CONECTAR"
                            Style="{StaticResource AccentButton}"
                            FontSize="14" FontWeight="Bold"
                            Padding="0,12" Margin="0,16,0,0"
                            Click="Connect_Click"/>

                    <!-- Recentes -->
                    <TextBlock Text="Recentes" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,16,0,6"/>
                    <ItemsControl x:Name="RecentList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Display}"
                                        Tag="{Binding Host}"
                                        Style="{StaticResource QuickAccessButton}"
                                        Click="Recent_Click"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        HorizontalAlignment="Left"
                                        Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3" Background="{DynamicResource AccentDarkBrush}">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Pronto" Foreground="White" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
