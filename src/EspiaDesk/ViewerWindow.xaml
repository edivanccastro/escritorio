<Window x:Class="EspiaDesk.ViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EspiaDesk — Visualizador Remoto"
        Width="1100" Height="720"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Icon="pack://application:,,,/Assets/espiadisk.ico"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar da sessão -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Identidade -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="2" Background="White" Margin="0,0,8,0">
                        <TextBlock Text="E" FontWeight="Bold" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <TextBlock x:Name="TxtTitle" Foreground="White" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Ações centrais -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource QuickAccessButton}" Content="&#xE8C6;" ToolTip="Enviar Arquivo"   Click="SendFile_Click"/>
                    <Button Style="{StaticResource QuickAccessButton}" Content="&#xE8BD;" ToolTip="Chat"             Click="Chat_Click"/>
                    <Button Style="{StaticResource QuickAccessButton}" Content="&#xE8C8;" ToolTip="Sincronizar Área de Transferência" Click="Clipboard_Click"/>
                    <Button Style="{StaticResource QuickAccessButton}" Content="&#xE740;" ToolTip="Screenshot"       Click="Screenshot_Click"/>
                    <Button Style="{StaticResource QuickAccessButton}" Content="&#xE740;" ToolTip="Tela Cheia (F11)" Click="Fullscreen_Click"/>
                </StackPanel>

                <!-- Qualidade + desconectar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Q:" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider x:Name="SldQuality" Minimum="20" Maximum="95" Value="60" Width="80"
                            ValueChanged="Quality_Changed" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtQuality" Text="60%" Foreground="White" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0,12,0"/>
                    <Button Content="✕ Desconectar" Foreground="White"
                            Background="#CC3333" BorderThickness="0"
                            Padding="10,4" FontSize="11"
                            Click="Disconnect_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Canvas da tela remota -->
        <Border Grid.Row="1" Background="Black">
            <Image x:Name="RemoteScreen"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   MouseMove="Screen_MouseMove"
                   MouseDown="Screen_MouseDown"
                   MouseUp="Screen_MouseUp"
                   MouseWheel="Screen_MouseWheel"
                   Cursor="Cross"
                   Focusable="True"/>
        </Border>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Background="{DynamicResource AccentDarkBrush}">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Conectado" Foreground="White" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtFps" Text="FPS: --" Foreground="#AAFFFFFF" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TxtResolution" Text="" Foreground="#AAFFFFFF" FontSize="11" Margin="8,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
